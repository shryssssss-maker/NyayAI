# ─────────────────────────────────────────────
# NYAYAAI — .env.example
# Copy this to .env and fill in your values
# Never commit .env to git
# ─────────────────────────────────────────────


# ══════════════════════════════════════════════
# APP
# ══════════════════════════════════════════════
APP_ENV=development                          # development | staging | production
APP_NAME=NyayaAI
APP_VERSION=4.0.0
DEBUG=true
LOG_LEVEL=info                               # debug | info | warning | error


# ══════════════════════════════════════════════
# BACKEND — FastAPI
# ══════════════════════════════════════════════
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ══════════════════════════════════════════════
# FRONTEND — Next.js
# ══════════════════════════════════════════════
NEXT_PUBLIC_APP_NAME=NyayaAI
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ENV=development


# ══════════════════════════════════════════════
# AUTH — JWT
# ══════════════════════════════════════════════
SECRET_KEY=change-this-to-a-random-256-bit-string
JWT_SECRET=change-this-to-another-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30


# ══════════════════════════════════════════════
# AUTH — NextAuth (Frontend)
# ══════════════════════════════════════════════
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000


# ══════════════════════════════════════════════
# DATABASE — PostgreSQL
# ══════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nyaya
POSTGRES_PASSWORD=nyaya123
POSTGRES_DB=nyayaai

# Async URL (used by FastAPI / SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://nyaya:nyaya123@localhost:5432/nyayaai

# Sync URL (used by Alembic migrations)
SYNC_DATABASE_URL=postgresql://nyaya:nyaya123@localhost:5432/nyayaai


# ══════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                              # Leave blank if no auth (local dev)
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Separate DBs for different purposes
REDIS_CACHE_DB=0
REDIS_CELERY_DB=1
REDIS_PUBSUB_DB=2

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ══════════════════════════════════════════════
# QDRANT — Vector Database
# ══════════════════════════════════════════════
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                              # Leave blank for local dev
QDRANT_HTTPS=false

# Collection names
QDRANT_COLLECTION_STATUTES=nyayaai_statutes
QDRANT_COLLECTION_CASELAW=nyayaai_caselaw
QDRANT_COLLECTION_DOCUMENTS=nyayaai_documents

# Vector config
QDRANT_VECTOR_SIZE=1536                      # OpenAI text-embedding-3-large
QDRANT_DISTANCE=Cosine


# ══════════════════════════════════════════════
# NEO4J — Graph Database
# ══════════════════════════════════════════════
NEO4J_GRAPH_ENABLED=false                   # Keep OFF until graph validation is complete
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nyaya123
NEO4J_DATABASE=neo4j                         # Default DB name
NEO4J_CORPUS_PATH=app/data/corpus            # Preferred source path for graph ingestion


# ══════════════════════════════════════════════
# LLM — OpenAI
# ══════════════════════════════════════════════
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=                               # Optional — your org ID
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini               # For cheaper/faster calls
OPENAI_MODEL_EMBEDDING=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1                       # Low temp for legal accuracy


# ══════════════════════════════════════════════
# LLM — Anthropic (Claude)
# ══════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-opus-4-5             # Primary model
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001  # For fast/cheap tasks
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.1


# ══════════════════════════════════════════════
# AGENTS — Pipeline Config
# ══════════════════════════════════════════════

# Which LLM to use per agent (openai | anthropic)
AGENT_INTAKE_PROVIDER=anthropic
AGENT_RESEARCH_PROVIDER=openai
AGENT_DOCUMENT_PROVIDER=anthropic
AGENT_STRATEGY_PROVIDER=anthropic
AGENT_EXPLAINABILITY_PROVIDER=openai

# Pipeline settings
PIPELINE_TIMEOUT_SECONDS=45                  # Max time for full pipeline
PIPELINE_MAX_RETRIES=3
PIPELINE_CONFIDENCE_THRESHOLD=0.6            # Min confidence to surface result

# Research agent
RESEARCH_TOP_K=10                            # Number of statute chunks to retrieve
RESEARCH_SCORE_THRESHOLD=0.75               # Min similarity score

# Lawyer matching
MATCHING_TOP_N=5                             # Number of lawyers to surface
MATCHING_MIN_SCORE=0.4                       # Min match score to show


# ══════════════════════════════════════════════
# OTP / SMS — Twilio
# ══════════════════════════════════════════════
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6


# ══════════════════════════════════════════════
# EMAIL (optional — for lawyer verification alerts)
# ══════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password              # Gmail app password, not account password
SMTP_FROM=noreply@nyayaai.in
SMTP_TLS=true


# ══════════════════════════════════════════════
# FILE STORAGE
# ══════════════════════════════════════════════

# Local (development)
STORAGE_BACKEND=local                        # local | s3
LOCAL_STORAGE_PATH=./storage/uploads

# AWS S3 (production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1                        # Mumbai — closest to India
AWS_S3_BUCKET=nyayaai-uploads
AWS_S3_BUCKET_DOCUMENTS=nyayaai-documents

# Max upload size
MAX_UPLOAD_SIZE_MB=20


# ══════════════════════════════════════════════
# OCR — Tesseract
# ══════════════════════════════════════════════
TESSERACT_CMD=/usr/local/bin/tesseract       # Mac: brew install tesseract
# TESSERACT_CMD=/usr/bin/tesseract           # Linux
TESSERACT_LANG=eng+hin                       # English + Hindi


# ══════════════════════════════════════════════
# INDIANKANOON — Case Law
# ══════════════════════════════════════════════
INDIANKANOON_API_KEY=your-indiankanoon-api-key
INDIANKANOON_BASE_URL=https://api.indiankanoon.org


# ══════════════════════════════════════════════
# UNASSIGNED CASE ESCALATION
# ══════════════════════════════════════════════
UNASSIGNED_THRESHOLD_HOURS=72               # Escalate after 72hrs with no offers
ESCALATION_CHECK_INTERVAL_MINUTES=30        # How often Celery checks
ESCALATION_NOTIFY_LAWYERS=true


# ══════════════════════════════════════════════
# NOTIFICATIONS
# ══════════════════════════════════════════════
NOTIFICATION_CHANNELS=inapp,email           # inapp | email | push
PUSH_NOTIFICATIONS_ENABLED=false            # Not in v4 scope


# ══════════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_PIPELINE_PER_HOUR=10             # Max pipeline runs per citizen per hour


# ══════════════════════════════════════════════
# MONITORING (optional)
# ══════════════════════════════════════════════
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1


# ══════════════════════════════════════════════
# LAWYER VERIFICATION
# ══════════════════════════════════════════════
LAWYER_VERIFICATION_MODE=manual             # manual | api (Bar Council API in roadmap)
PROFILE_COMPLETENESS_MIN_SCORE=60           # Below this = ranked lower in search


# ══════════════════════════════════════════════
# DOCUMENT GENERATION
# ══════════════════════════════════════════════
DOCX_TEMPLATE_DIR=./agents/document/templates
PDF_EXPORT_ENABLED=true
WATERMARK_DRAFT_DOCS=true                   # Add DRAFT watermark before lawyer review
